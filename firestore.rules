rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: classes
    // Document ID: classId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - enabled: boolean (required)
    //
    // Collection: subjects
    // Document ID: subjectId
    // Fields:
    //   - id: string (required)
    //   - classId: string (required)
    //   - name: string (required)
    //   - enabled: boolean (required)
    //
    // Collection: chapters
    // Document ID: chapterId
    // Fields:
    //   - id: string (required)
    //   - subjectId: string (required)
    //   - classId: string (required)
    //   - name: string (required)
    //   - resources: array (required)
    //   - quiz: array (required)
    //   - isImportant: boolean (required)
    //   - enabled: boolean (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - name: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, ['admin', 'student'])
    //
    // Collection: settings
    // Document ID: settingId
    // Fields:
    //   - isMusicEnabled: boolean (optional)
    //
    // Collection: userProgress
    // Document ID: progressId
    // Fields:
    //   - userId: string (required)
    //   - chapterId: string (required)
    //   - completedAt: timestamp (required)
    //
    // Collection: quizHistory
    // Document ID: historyId
    // Fields:
    //   - userId: string (required)
    //   - chapterId: string (required)
    //   - score: number (required)
    //   - total: number (required)
    //   - completedAt: timestamp (required)
    //
    // Collection: comments
    // Document ID: commentId
    // Fields:
    //   - id: string (required)
    //   - chapterId: string (required)
    //   - userId: string (required)
    //   - userName: string (required)
    //   - text: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: tests
    // Document ID: testId
    // Fields:
    //   - id: string (required)
    //   - classId: string (required)
    //   - title: string (required)
    //   - questions: array (required)
    //   - active: boolean (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: testResults
    // Document ID: resultId
    // Fields:
    //   - testId: string (required)
    //   - studentName: string (required)
    //   - score: number (required)
    //   - total: number (required)
    //   - completedAt: timestamp (required)
    //
    // Collection: groups
    // Document ID: groupId
    // Fields:
    //   - name: string (required)
    //   - description: string (required)
    //   - password: string (optional)
    //   - createdAt: timestamp (required)
    //   - createdBy: string (required)
    //
    // Collection: ratings
    // Document ID: ratingId
    // Fields:
    //   - studentUid: string (required)
    //   - studentName: string (required)
    //   - score: number (required)
    //   - comment: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: config
    // Document ID: site
    // Fields:
    //   - isRatingEnabled: boolean (optional)
    //   - welcomeEmailSubject: string (optional)
    //   - welcomeEmailTemplate: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
             'email' in request.auth.token && 
             request.auth.token.email.toLower() == "vijayninama683@gmail.com";
    }

    function isAdmin() {
      return isAuthenticated() && 
        (
          isSuperAdmin() ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isLegend', false) == true))
        );
    }

    function isValidClass(data) {
      return data.keys().hasAll(['id', 'name', 'enabled']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.enabled is bool &&
             (!('order' in data) || data.order is number);
    }

    function isValidSubject(data) {
      return data.keys().hasAll(['id', 'classId', 'name', 'enabled']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.classId is string && data.classId.size() > 0 && data.classId.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.enabled is bool &&
             (!('order' in data) || data.order is number);
    }

    function isValidChapter(data) {
      return data.keys().hasAll(['id', 'subjectId', 'classId', 'name']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 50 &&
             data.subjectId is string && data.subjectId.size() > 0 && data.subjectId.size() < 50 &&
             data.classId is string && data.classId.size() > 0 && data.classId.size() < 50 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             (!('resources' in data) || data.resources is list) &&
             (!('quiz' in data) || data.quiz is list) &&
             (!('quizEnabled' in data) || data.quizEnabled is bool) &&
             (!('isImportant' in data) || data.isImportant is bool) &&
             (!('enabled' in data) || data.enabled is bool) &&
             (!('order' in data) || data.order is number);
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'] &&
             (!('name' in data) || data.name is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('photoURLOverridden' in data) || data.photoURLOverridden is bool) &&
             (!('adminKey' in data) || data.adminKey is string) &&
             (!('isLegend' in data) || data.isLegend is bool) &&
             (!('isSecret' in data) || data.isSecret is bool) &&
             (!('secretLoginLogged' in data) || data.secretLoginLogged is bool) &&
             (!('totalTimeSpent' in data) || data.totalTimeSpent is number) &&
             (!('bonusTimeSpent' in data) || data.bonusTimeSpent is number) &&
             (!('welcomeSent' in data) || data.welcomeSent is bool) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('lastActive' in data) || (data.lastActive is timestamp || data.lastActive == request.time)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt == request.time)) &&
             (!('lastLocation' in data) || data.lastLocation is map) &&
             (!('ip' in data) || data.ip is string) &&
             (!('deviceInfo' in data) || data.deviceInfo is map);
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['id']) &&
             data.id is string &&
             (!('neonBlue' in data) || data.neonBlue is string) &&
             (!('neonPurple' in data) || data.neonPurple is string) &&
             (!('neonPink' in data) || data.neonPink is string) &&
             (!('neonMagenta' in data) || data.neonMagenta is string) &&
             (!('darkBg' in data) || data.darkBg is string) &&
             (!('darkCard' in data) || data.darkCard is string) &&
             (!('darkBorder' in data) || data.darkBorder is string);
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['userId', 'chapterId', 'completedAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.chapterId is string && data.chapterId.size() > 0 &&
             data.completedAt is timestamp;
    }

    function isValidQuizHistory(data) {
      return data.keys().hasAll(['userId', 'chapterId', 'score', 'total', 'completedAt']) &&
             data.userId is string && data.userId == request.auth.uid &&
             data.chapterId is string && data.chapterId.size() > 0 &&
             data.score is number && data.total is number &&
             data.completedAt is timestamp;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['chapterId', 'userId', 'userName', 'text', 'createdAt']) &&
             data.chapterId is string && data.chapterId.size() > 0 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() > 0 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidTest(data) {
      return data.keys().hasAll(['id', 'classId', 'title', 'questions', 'active', 'createdAt']) &&
             data.id is string && data.id.size() > 0 &&
             data.classId is string && data.classId.size() > 0 &&
             data.title is string && data.title.size() > 0 &&
             data.questions is list &&
             data.active is bool &&
             data.createdAt is timestamp;
    }

    function isValidTestResult(data) {
      return data.keys().hasAll(['testId', 'studentName', 'score', 'total', 'completedAt']) &&
             data.testId is string && data.testId.size() > 0 &&
             data.studentName is string && data.studentName.size() > 0 &&
             data.score is number && data.total is number &&
             (data.completedAt is timestamp || data.completedAt == request.time) &&
             (!('studentUid' in data) || (data.studentUid is string && data.studentUid == request.auth.uid));
    }

    function isValidSiteComment(data) {
      return data.keys().hasAll(['userName', 'text', 'likes', 'likedBy', 'createdAt']) &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
             data.likes is number &&
             data.likedBy is list &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('parentId' in data) || (data.parentId is string && data.parentId.size() > 0)) &&
             (!('groupId' in data) || (data.groupId is string && data.groupId.size() > 0)) &&
             (!('userUid' in data) || (data.userUid is string && data.userUid.size() > 0));
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'description', 'createdAt', 'createdBy']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() < 500 &&
             (!('password' in data) || data.password is string) &&
             (!('enabled' in data) || data.enabled is bool) &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             data.createdBy is string &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt == request.time));
    }

    function isValidRating(data) {
      return data.keys().hasAll(['studentUid', 'studentName', 'score', 'createdAt']) &&
             data.studentUid is string && data.studentUid == request.auth.uid &&
             data.studentName is string && data.studentName.size() > 0 &&
             data.score is number && data.score >= 1 && data.score <= 10 &&
             (!('studentEmail' in data) || data.studentEmail is string) &&
             (!('studentPhotoURL' in data) || data.studentPhotoURL is string) &&
             (!('comment' in data) || data.comment is string) &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidConfig(data) {
      return (!('isRatingEnabled' in data) || data.isRatingEnabled is bool) &&
             (!('ratingQuestion' in data) || (data.ratingQuestion is string && data.ratingQuestion.size() < 500)) &&
             (!('welcomeEmailSubject' in data) || data.welcomeEmailSubject is string) &&
             (!('welcomeEmailTemplate' in data) || data.welcomeEmailTemplate is string) &&
             (!('welcomeEmailSender' in data) || data.welcomeEmailSender is string) &&
             (!('emailjsServiceId' in data) || data.emailjsServiceId is string) &&
             (!('emailjsTemplateId' in data) || data.emailjsTemplateId is string) &&
             (!('emailjsPublicKey' in data) || data.emailjsPublicKey is string) &&
             (!('siteName' in data) || (data.siteName is string && data.siteName.size() < 100)) &&
             (!('adminName' in data) || (data.adminName is string && data.adminName.size() < 100)) &&
             (!('coOwnerName' in data) || (data.coOwnerName is string && data.coOwnerName.size() < 100)) &&
             (!('siteSubtitle' in data) || (data.siteSubtitle is string && data.siteSubtitle.size() < 1000)) &&
             (!('announcementText' in data) || (data.announcementText is string && data.announcementText.size() < 5000)) &&
             (!('showAnnouncement' in data) || data.showAnnouncement is bool) &&
             (!('maintenanceMode' in data) || data.maintenanceMode is bool) &&
             (!('maintenanceMessage' in data) || (data.maintenanceMessage is string && data.maintenanceMessage.size() < 1000)) &&
             (!('autoApproveUsers' in data) || data.autoApproveUsers is bool) &&
             (!('defaultThemeMode' in data) || (data.defaultThemeMode in ['dark', 'light', 'auto'])) &&
             (!('ipLockdownEnabled' in data) || data.ipLockdownEnabled is bool) &&
             (!('showNewBadge' in data) || data.showNewBadge is bool) &&
             (!('testTimeMultiplier' in data) || data.testTimeMultiplier is number) &&
             (!('termsUrl' in data) || (data.termsUrl is string && data.termsUrl.size() < 1000)) &&
             (!('privacyUrl' in data) || (data.privacyUrl is string && data.privacyUrl.size() < 1000)) &&
             (!('searchEnabled' in data) || data.searchEnabled is bool) &&
             (!('gamesEnabled' in data) || data.gamesEnabled is bool) &&
             (!('liveClubEnabled' in data) || data.liveClubEnabled is bool) &&
             (!('bgEffect' in data) || (data.bgEffect in ['none', 'snow', 'confetti', 'stars'])) &&
             (!('secretLoginEnabled' in data) || data.secretLoginEnabled is bool) &&
             (!('secretLoginKey' in data) || (data.secretLoginKey is string && data.secretLoginKey.size() < 100)) &&
             (!('secretProfiles' in data) || data.secretProfiles is list) &&
             (!('limitedAdminTabs' in data) || data.limitedAdminTabs is list) &&
             (!('adminUnlockKey' in data) || (data.adminUnlockKey is string && data.adminUnlockKey.size() < 50)) &&
             (!('supportWhatsApp' in data) || (data.supportWhatsApp is string && data.supportWhatsApp.size() < 50)) &&
             (!('supportTelegram' in data) || (data.supportTelegram is string && data.supportTelegram.size() < 200)) &&
             (!('supportEmail' in data) || (data.supportEmail is string && data.supportEmail.size() < 200)) &&
             (!('musicEnabled' in data) || data.musicEnabled is bool) &&
             (!('musicPassword' in data) || (data.musicPassword is string && data.musicPassword.size() < 100)) &&
             (!('logoUrl' in data) || (data.logoUrl is string && data.logoUrl.size() < 1000)) &&
             (!('logoColor' in data) || (data.logoColor is string && data.logoColor.size() < 20)) &&
             (!('logoColorSecondary' in data) || (data.logoColorSecondary is string && data.logoColorSecondary.size() < 20)) &&
             (!('logoColorTertiary' in data) || (data.logoColorTertiary is string && data.logoColorTertiary.size() < 20)) &&
             (!('logoInnerColor' in data) || (data.logoInnerColor is string && data.logoInnerColor.size() < 20)) &&
             (!('logoInnerColorSecondary' in data) || (data.logoInnerColorSecondary is string && data.logoInnerColorSecondary.size() < 20)) &&
             (!('logoInnerColorTertiary' in data) || (data.logoInnerColorTertiary is string && data.logoInnerColorTertiary.size() < 20)) &&
             (!('faviconUrl' in data) || (data.faviconUrl is string && data.faviconUrl.size() < 1000)) &&
             (!('socialInstagram' in data) || (data.socialInstagram is string && data.socialInstagram.size() < 100)) &&
             (!('socialFacebook' in data) || (data.socialFacebook is string && data.socialFacebook.size() < 500)) &&
             (!('showFooterCredit' in data) || data.showFooterCredit is bool) &&
             (!('leaderboardVisible' in data) || data.leaderboardVisible is bool) &&
             (!('registrationEnabled' in data) || data.registrationEnabled is bool) &&
             (!('notificationDuration' in data) || data.notificationDuration is number) &&
             (!('watermarkText' in data) || (data.watermarkText is string && data.watermarkText.size() < 500)) &&
             (!('watermarkEnabled' in data) || data.watermarkEnabled is bool) &&
             (!('bannedIps' in data) || data.bannedIps is list) &&
             (!('studyTimerEnabled' in data) || data.studyTimerEnabled is bool) &&
             (!('globalLeaderboardEnabled' in data) || data.globalLeaderboardEnabled is bool) &&
             (!('guestModeEnabled' in data) || data.guestModeEnabled is bool) &&
             (!('customFooterText' in data) || (data.customFooterText is string && data.customFooterText.size() < 5000)) &&
             (!('announcementColor' in data) || (data.announcementColor is string && data.announcementColor.size() < 50)) &&
             (!('verifyUserEmail' in data) || data.verifyUserEmail is bool) &&
             (!('secretLoginPassword' in data) || (data.secretLoginPassword is string && data.secretLoginPassword.size() < 100)) &&
             (!('lastUpdated' in data) || (data.lastUpdated is timestamp || data.lastUpdated == request.time));
    }

    function isValidMusic(data) {
      return data.keys().hasAll(['id', 'title', 'url', 'order']) &&
             data.id is string && data.title is string && 
             data.url is string && data.order is number &&
             (!('artist' in data) || data.artist is string) &&
             (!('coverUrl' in data) || data.coverUrl is string);
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'message', 'type', 'createdAt']) &&
             data.title is string && data.message is string &&
             data.type in ['info', 'success', 'warning', 'error'] &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('url' in data) || data.url is string) &&
             (!('createdBy' in data) || data.createdBy is string);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'createdAt']) &&
             data.title is string && data.message is string &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('type' in data) || data.type is string) &&
             (!('url' in data) || data.url is string) &&
             (!('createdBy' in data) || data.createdBy is string) &&
             (!('userId' in data) || data.userId is string);
    }

    function isValidSentEmail(data) {
      return data.keys().hasAll(['to', 'message', 'sentAt', 'type']) &&
             data.to is string && data.to.size() > 0 &&
             data.message is map &&
             data.message.keys().hasAll(['subject', 'html']) &&
             data.message.subject is string &&
             data.message.html is string &&
             (data.sentAt is timestamp || data.sentAt == request.time) &&
             data.type is string;
    }

    function isValidBulkMessage(data) {
      return data.keys().hasAll(['topic', 'data', 'sentAt', 'recipientCount']) &&
             data.topic is string && data.topic.size() > 0 &&
             data.data is string && data.data.size() > 0 &&
             (data.sentAt is timestamp || data.sentAt == request.time) &&
             data.recipientCount is number;
    }

    function isValidActivityLog(data) {
      return data.keys().hasAll(['userId', 'action', 'timestamp']) &&
             data.userId is string &&
             data.action is string &&
             (data.timestamp is timestamp || data.timestamp == request.time) &&
             (!('userName' in data) || data.userName is string) &&
             (!('userEmail' in data) || data.userEmail is string) &&
             (!('path' in data) || data.path is string) &&
             (!('ip' in data) || data.ip is string) &&
             (!('isSecret' in data) || data.isSecret is bool) &&
             (!('resolution' in data) || data.resolution is string) &&
             (!('userAgent' in data) || data.userAgent is string);
    }

    function isValidUserMessage(data) {
      return data.keys().hasAll(['userId', 'message', 'createdAt']) &&
             data.userId is string &&
             data.message is string &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (!('duration' in data) || data.duration is number) &&
             (!('showCount' in data) || data.showCount is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidClass(request.resource.data);
      allow delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidSubject(request.resource.data);
      allow delete: if isAdmin();
    }

    match /chapters/{chapterId} {
      allow get, list: if true;
      allow create, update: if isAdmin() && isValidChapter(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && 
        (
          (request.resource.data.role == 'student' && request.resource.data.get('isLegend', false) == false) || 
          (request.resource.data.get('isLegend', false) == true && (request.resource.data.get('adminKey', '') == 'Vijay1987' || (exists(/databases/$(database)/documents/config/site) && request.resource.data.get('adminKey', '') == get(/databases/$(database)/documents/config/site).data.get('secretLoginKey', '')))) ||
          isSuperAdmin() ||
          (request.resource.data.role == 'admin' && (request.resource.data.get('adminKey', '') == 'Vijay1987' || (exists(/databases/$(database)/documents/config/site) && request.resource.data.get('adminKey', '') == get(/databases/$(database)/documents/config/site).data.get('secretLoginKey', ''))))
        );
      allow update: if isAuthenticated() && 
        (
          isSuperAdmin() || 
          (
            (
              (isAdmin() && resource.data.get('email', '').toLower() != "vijayninama683@gmail.com") || 
              (request.auth.uid == userId)
            ) &&
            // Prevent non-super-admins from changing bonus time
            request.resource.data.get('bonusTimeSpent', 0) == resource.data.get('bonusTimeSpent', 0) &&
            (
              (request.resource.data.role == resource.data.role && request.resource.data.get('isLegend', false) == resource.data.get('isLegend', false)) ||
              ((request.resource.data.role == 'admin' || request.resource.data.get('isLegend', false) == true) && (request.resource.data.get('adminKey', '') == 'Vijay1987' || (exists(/databases/$(database)/documents/config/site) && request.resource.data.get('adminKey', '') == get(/databases/$(database)/documents/config/site).data.get('secretLoginKey', ''))))
            )
          )
        ) && isValidUser(request.resource.data);
      allow delete: if isAdmin() && resource.data.get('email', '').toLower() != "vijayninama683@gmail.com";
    }

    match /userProgress/{progressId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidUserProgress(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /quizHistory/{historyId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidQuizHistory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /tests/{testId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTest(request.resource.data);
      allow delete: if isAdmin();
    }

    match /testResults/{resultId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidTestResult(request.resource.data);
      allow delete: if isAdmin();
    }

    match /siteComments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidSiteComment(request.resource.data) && 
                      request.resource.data.get('userUid', '') == request.auth.uid;
      allow update: if isAuthenticated() && isValidSiteComment(request.resource.data) && 
                      (isAdmin() || 
                       (request.resource.data.get('userUid', '') == resource.data.get('userUid', '') && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy'])));
      allow delete: if isAdmin();
    }

    match /groups/{groupId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidGroup(request.resource.data);
      allow delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.studentUid == request.auth.uid));
      allow create: if isAuthenticated() && isValidRating(request.resource.data);
      allow delete: if isAdmin();
    }

    match /config/{docId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidConfig(request.resource.data);
      allow delete: if isAdmin();
    }

    match /music/{songId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidMusic(request.resource.data);
      allow delete: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidNews(request.resource.data);
      allow delete: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAdmin() || 
                    (resource.data.get('userId', '') == '' || resource.data.get('userId', '') == 'all') || 
                    (isAuthenticated() && resource.data.get('userId', '') == request.auth.uid);
      allow create, update: if isAdmin() && isValidNotification(request.resource.data);
      allow delete: if isAdmin();
    }

    match /sentEmails/{emailId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidSentEmail(request.resource.data);
    }

    match /bulkMessages/{msgId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidBulkMessage(request.resource.data);
    }

    match /activityLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidActivityLog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /userMessages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'all'));
      allow create, delete: if isAdmin() && (request.resource == null || isValidUserMessage(request.resource.data));
      allow update: if (isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid)) && isValidUserMessage(request.resource.data);
    }
  }
}
