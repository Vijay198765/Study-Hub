{
  "entities": {
    "Class": {
      "title": "Class",
      "description": "A school class (e.g., Class 10, Class 12)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["id", "name", "enabled", "order"]
    },
    "Subject": {
      "title": "Subject",
      "description": "A subject within a class (e.g., Physics, Maths)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "name": { "type": "string" },
        "enabled": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["id", "classId", "name", "enabled", "order"]
    },
    "Chapter": {
      "title": "Chapter",
      "description": "A chapter within a subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subjectId": { "type": "string" },
        "classId": { "type": "string" },
        "name": { "type": "string" },
        "resources": { "type": "array" },
        "quiz": { "type": "array" },
        "quizEnabled": { "type": "boolean" },
        "isImportant": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "order": { "type": "number" }
      },
      "required": ["id", "subjectId", "classId", "name", "resources", "quiz", "quizEnabled", "isImportant", "enabled", "order"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "ip": { "type": "string" },
        "deviceInfo": {
          "type": "object",
          "properties": {
            "userAgent": { "type": "string" },
            "platform": { "type": "string" },
            "language": { "type": "string" },
            "screenResolution": { "type": "string" },
            "ip": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Logs of user activity on the site",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "action": { "type": "string" },
        "path": { "type": "string" },
        "ip": { "type": "string" },
        "resolution": { "type": "string" },
        "userAgent": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "action", "timestamp"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "Tracks completed chapters for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "chapterId": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "chapterId", "completedAt"]
    },
    "QuizHistory": {
      "title": "QuizHistory",
      "description": "Saves quiz scores for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "chapterId": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "chapterId", "score", "total", "completedAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment in the discussion forum",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chapterId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "chapterId", "userId", "userName", "text", "createdAt"]
    },
    "Test": {
      "title": "Test",
      "description": "An admin-launched test for a class",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "classId": { "type": "string" },
        "title": { "type": "string" },
        "questions": { "type": "array" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "classId", "title", "questions", "active", "createdAt"]
    },
    "TestResult": {
      "title": "TestResult",
      "description": "A student's result for a launched test",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "studentName": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["testId", "studentName", "score", "total", "completedAt"]
    },
    "SiteComment": {
      "title": "SiteComment",
      "description": "A general comment about the website",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userName": { "type": "string" },
        "text": { "type": "string" },
        "likes": { "type": "number" },
        "likedBy": { "type": "array" },
        "parentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userName", "text", "likes", "likedBy", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "neonBlue": { "type": "string" },
        "neonPurple": { "type": "string" },
        "neonPink": { "type": "string" },
        "neonMagenta": { "type": "string" },
        "darkBg": { "type": "string" },
        "darkCard": { "type": "string" },
        "darkBorder": { "type": "string" }
      },
      "required": ["id"]
    },
    "Config": {
      "title": "Config",
      "description": "Site configuration",
      "type": "object",
      "properties": {
        "isRatingEnabled": { "type": "boolean" },
        "ratingQuestion": { "type": "string" },
        "welcomeEmailSubject": { "type": "string" },
        "welcomeEmailTemplate": { "type": "string" },
        "siteName": { "type": "string" },
        "adminName": { "type": "string" },
        "siteSubtitle": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "maintenanceMessage": { "type": "string" },
        "autoApproveUsers": { "type": "boolean" },
        "defaultThemeMode": { "type": "string" },
        "ipLockdownEnabled": { "type": "boolean" },
        "showNewBadge": { "type": "boolean" },
        "testTimeMultiplier": { "type": "number" },
        "termsUrl": { "type": "string" },
        "privacyUrl": { "type": "string" },
        "searchEnabled": { "type": "boolean" },
        "gamesEnabled": { "type": "boolean" },
        "liveClubEnabled": { "type": "boolean" },
        "announcementText": { "type": "string" },
        "showAnnouncement": { "type": "boolean" },
        "bgEffect": { "type": "string" },
        "secretLoginEnabled": { "type": "boolean" },
        "secretLoginKey": { "type": "string" },
        "limitedAdminTabs": { "type": "array", "items": { "type": "string" } },
        "adminUnlockKey": { "type": "string" },
        "supportWhatsApp": { "type": "string" },
        "supportTelegram": { "type": "string" },
        "supportEmail": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Collection of classes"
    },
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Collection of subjects"
    },
    "/chapters/{chapterId}": {
      "schema": "Chapter",
      "description": "Collection of chapters"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/userProgress/{progressId}": {
      "schema": "UserProgress",
      "description": "User chapter completion status"
    },
    "/quizHistory/{historyId}": {
      "schema": "QuizHistory",
      "description": "User quiz history"
    },
    "/comments/{commentId}": {
      "schema": "Comment",
      "description": "Discussion forum comments"
    },
    "/tests/{testId}": {
      "schema": "Test",
      "description": "Admin-launched tests"
    },
    "/testResults/{resultId}": {
      "schema": "TestResult",
      "description": "Test results for scoreboard"
    },
    "/siteComments/{commentId}": {
      "schema": "SiteComment",
      "description": "General website feedback and comments"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Global application settings"
    },
    "/activityLogs/{logId}": {
      "schema": "ActivityLog",
      "description": "User activity logs"
    },
    "/config/{docId}": {
      "schema": "Config",
      "description": "Site configuration"
    }
  }
}
